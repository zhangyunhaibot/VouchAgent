# === LLM 配置(DeepSeek，OpenAI 兼容接口) ===
# DeepSeek API Key（从 platform.deepseek.com 申请）
DEEPSEEK_API_KEY=sk-xxxxx
# OpenAI 兼容接口地址
LLM_BASE_URL=https://api.deepseek.com
# 模型（deepseek-v4-flash 便宜快；想更强可换 deepseek-v4-pro）
LLM_MODEL=deepseek-v4-flash

# === 链上配置(部署合约后填写) ===
# 已部署的 RwaOracle 合约 package hash
CONTRACT_HASH=hash-37cc023989e5689fe47e264caeb46f24483feb2ecc513f7f4d2ec1de03267ebd
# 预言机 Agent 私钥文件路径(部署阶段配置，私钥由用户自管)
ORACLE_SECRET_KEY=keys/secret_key.pem
# Casper 测试网节点（官方公共节点，免鉴权）
NODE_ADDRESS=https://node.testnet.casper.network
EVENTS_URL=https://node.testnet.casper.network/events
CHAIN_NAME=casper-test

# === x402 配置 ===
X402_FACILITATOR=https://x402-facilitator.cspr.cloud
X402_NETWORK=casper:casper-test
